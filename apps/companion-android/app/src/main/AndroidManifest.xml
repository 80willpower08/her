<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.her.companion">

    <!-- The ONLY non-internet permission this app uses. Notification access is
         granted by the user via Android Settings → Notifications → Special app
         access → Notification access, not at install time. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Listed only so Android's Settings UI lets us register; the actual
         binding is enforced via android:permission on the service below. -->
    <uses-permission android:name="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
        tools:ignore="ProtectedPermissions"
        xmlns:tools="http://schemas.android.com/tools" />
    <!-- READ_SMS is requested at runtime and used ONLY by SmsBackfillActivity
         when the user explicitly taps "Backfill SMS history". Listener path
         doesn't touch the SMS provider. -->
    <uses-permission android:name="android.permission.READ_SMS" />

    <application
        android:label="@string/app_name"
        android:icon="@drawable/ic_launcher"
        android:roundIcon="@drawable/ic_launcher"
        android:theme="@style/Theme.HerCompanion"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false">

        <activity
            android:name=".SettingsActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".SmsBackfillActivity"
            android:exported="false"
            android:parentActivityName=".SettingsActivity" />

        <!-- The notification listener. Android only delivers events to it
             after the user grants access via Settings → Notification access. -->
        <service
            android:name=".HerNotificationListener"
            android:label="@string/listener_label"
            android:exported="true"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>
    </application>
</manifest>
