<?xml version="1.0" encoding="utf-8"?>
<!-- Deny all auto-backup of this app's data. The ingest token is sensitive
     and shouldn't end up in Google's Drive backups. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" />
        <exclude domain="database" />
        <exclude domain="file" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" />
        <exclude domain="database" />
        <exclude domain="file" />
    </device-transfer>
</data-extraction-rules>
