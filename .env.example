# ════════════════════════════════════════════════════════════════════════
# Time-keeper — env template
# Copy to `.env` and fill in. `.env` is gitignored.
# Generate secrets with the commands inline below each var.
# ════════════════════════════════════════════════════════════════════════

# ─── Postgres ────────────────────────────────────────────────────────────
POSTGRES_USER=timekeeper
# openssl rand -base64 32
POSTGRES_PASSWORD=changeme
POSTGRES_DB=timekeeper
DATABASE_URL=postgresql://timekeeper:changeme@postgres:5432/timekeeper

# ─── Redis ───────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Auth ────────────────────────────────────────────────────────────────
# Generate JWT_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-long-random-string
ADMIN_USERNAME=admin
# Generate ADMIN_PASSWORD_HASH with: pnpm hash-password 'your-password'
# For TrueNAS prod use ADMIN_PASSWORD_HASH_B64 instead (TrueNAS mangles `$`
# in env values). Compute it with: echo -n '$2b$12$...hash...' | base64
ADMIN_PASSWORD_HASH=

# ─── API ─────────────────────────────────────────────────────────────────
API_PORT=3001
NODE_ENV=development

# ─── Web (build-time) ────────────────────────────────────────────────────
# Local dev: http://localhost:8080 (through Caddy)
# Production: https://<your-subdomain>.example.com
VITE_API_URL=http://localhost:8080

# ─── Public origin / OAuth redirects ─────────────────────────────────────
# Must match what's registered in Google/Microsoft OAuth consoles.
# Local: http://localhost:8080
# Production: https://<your-subdomain>.example.com
PUBLIC_ORIGIN=http://localhost:8080

# Internal URL the worker + agent containers use to reach the api
# (Docker DNS — leave as-is for Docker Compose / TrueNAS)
API_INTERNAL_URL=http://api:3001

# Shared secret for worker/agent → api internal endpoints.
# openssl rand -hex 32
INTERNAL_API_SECRET=

# Pre-shared token for external SMS/share ingest (Tasker on phone, etc.)
# Posted as `X-Ingest-Token: <value>` header on POST /api/share.
# openssl rand -hex 32   — keep this private; phone-side only.
INGEST_TOKEN=

# Encryption key for OAuth tokens at rest.
# openssl rand -hex 32
ENCRYPTION_KEY=

# ─── OAuth providers ─────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MS_OAUTH_CLIENT_ID=
MS_OAUTH_CLIENT_SECRET=

# ─── Anthropic (Claude API) ──────────────────────────────────────────────
# Only used for image OCR on project import. The main agent uses your
# Claude Code subscription via `claude /login` — no API key needed there.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# ─── Agent cadence ───────────────────────────────────────────────────────
# Cron expression for the daily prioritization run (TZ-aware).
DAILY_AGENT_CRON=0 8 * * *
# IANA tz like America/Chicago. Also used to format times in agent context.
DAILY_AGENT_TZ=America/Chicago

# ─── Project attachments storage ─────────────────────────────────────────
# Bind-mount or volume path inside the api container.
ATTACHMENTS_DIR=/data/attachments

# ─── Push notifications (Web Push) ───────────────────────────────────────
# Generate VAPID keys with: pnpm dlx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact mailto: required by Web Push spec
VAPID_SUBJECT=mailto:admin@example.com

# Also exposed to the web client at build time
VITE_VAPID_PUBLIC_KEY=

# ─── ntfy fallback push ──────────────────────────────────────────────────
NTFY_URL=http://ntfy/
NTFY_TOPIC=her-notifications-replace-me
NTFY_BASE_URL=http://localhost:8081

# ─── Claude Code subscription mounts (agent container) ───────────────────
# Path on the host machine to your Claude Code credentials.
# Only needed if you run the agent locally with subscription auth.
# CLAUDE_CREDENTIALS_DIR=~/.claude
# CLAUDE_CONFIG_FILE=~/.claude.json
